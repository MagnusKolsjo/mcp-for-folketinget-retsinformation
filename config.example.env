# =============================================================================
# Databas
# Välj ETT av alternativen nedan. DATABASE_URL MÅSTE vara satt — servern
# startar inte utan den. Postgres och SQLite är symmetriska val.
# Postgres krävs för vektorsökning; SQLite fungerar för enklare installationer.
# =============================================================================

# PostgreSQL (krävs för vektorsökning med pgvector)
DATABASE_URL=postgresql://<ANVÄNDARE>@localhost:5432/riksdagstryck

# SQLite (välj detta explicit för installationer utan pgvector)
# DATABASE_URL=sqlite:///danmark_cache.db

# =============================================================================
# MCP-transport
# stdio och http är symmetriska val — välj det som passar ditt användningsfall.
# stdio: standard för Claude Desktop-integration
# http:  för flerklientinstallationer och direkta HTTP-anrop
# =============================================================================

MCP_TRANSPORT=stdio

# HTTP-transport (används bara om MCP_TRANSPORT=http)
MCP_HOST=127.0.0.1
MCP_PORT=8714
MCP_API_KEY=

# Anslutningspool (används bara om MCP_TRANSPORT=http)
# MCP_DB_POOL_MAX=5

# =============================================================================
# Termexpansion via LLM
# Valfritt — om QUERY_EXPANSION_ENABLED=false görs inga LLM-anrop vid sökning.
# Kräver en OpenAI-kompatibel endpoint (t.ex. Ollama lokalt).
# =============================================================================

QUERY_EXPANSION_ENABLED=false
# QUERY_EXPANSION_BASE_URL=http://localhost:11434/v1
# QUERY_EXPANSION_API_KEY=ollama
# QUERY_EXPANSION_MODEL=llama3

# Valfri promptfil för termexpansion (standard: inbyggd prompt används)
# QUERY_EXPANSION_PROMPT_FILE=prompts/expansion_prompt.txt

# =============================================================================
# Embeddingmodell
# Ingen nationell dansk sentence-transformer uppfyller kraven (DFM-medium har
# 32-token gräns — oanvändbar för lagtext; DFM-large har 1024 dim — avviker
# från projektstandard). intfloat/multilingual-e5-base är rätt kompromiss:
# 768 dim, 512 token kontext, fungerar väl för nordisk text.
# =============================================================================

EMBEDDING_MODELL=intfloat/multilingual-e5-base

# =============================================================================
# Chunkning och embedding
# 1500 tecken är medvetet dubbla standardrekommendationen (800) eftersom dansk
# lagtext har långa stycken som tappar sammanhang vid kortare chunks.
# =============================================================================

CHUNK_MAX_TECKEN=1500
CHUNK_MIN_TECKEN=100
CHUNK_OVERLAPP_TECKEN=200
EMBEDDING_BATCH_STORLEK=32

# =============================================================================
# PDF-cache
# Relativ sökväg ankras mot skriptets mapp.
# =============================================================================

PDF_CACHE_DIR=pdf_cache
PDF_CACHE_TTL_DAGAR=1

# =============================================================================
# Daglig synkning (används av synk_daglig.sh och installera_launchd)
# SCHEMALAGGARE: launchd (macOS, klarar att datorn sov vid schemalagd tid)
#                cron    (Linux)
# =============================================================================

SCHEMALAGGARE=launchd
# CRON_SCHEMA=0 3 * * *
# PYTHON_SOKVAG=/Users/<ANVÄNDARE>/MCP-Servers/.venv/bin/python

# =============================================================================
# Loggning
# =============================================================================

# LOGGRADER_BEHALL_DAGAR=30
